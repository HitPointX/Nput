{
  "name": "nput-frontend",
  "version": "0.1.0",
  "description": "Nput overlay renderer — connects to the backend and draws the overlay",
  "main": "dist/main.js",
  "scripts": {
    "build":     "tsc && cp src/index.html dist/index.html",
    "build:web": "tsc -p tsconfig.web.json",
    "start":     "npm run build && electron .",
    "dist":      "npm run build && electron-builder build",
    "dist:linux":"npm run build && electron-builder build --linux",
    "dist:win":  "npm run build && electron-builder build --win",
    "clean":     "rm -rf dist"
  },
  "build": {
    "appId":       "dev.nput.overlay",
    "productName": "Nput",
    "copyright":   "Copyright © 2025 Nput Contributors",
    "directories": {
      "output": "../dist-app"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map"
    ],
    "extraResources": [
      {
        "from": "../assets",
        "to":   "assets"
      },
      {
        "from": "../config",
        "to":   "config"
      },
      {
        "from": "../web",
        "to":   "web"
      }
    ],
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Utility",
      "extraResources": [
        {
          "from": "../backend/target/release/nput-backend",
          "to":   "backend/nput-backend"
        }
      ]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "extraResources": [
        {
          "from": "../backend/target/x86_64-pc-windows-gnu/release/nput-backend.exe",
          "to":   "backend/nput-backend.exe"
        }
      ]
    }
  },
  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript":       "^5.3.0",
    "@types/node":      "^20.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
